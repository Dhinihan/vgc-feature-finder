#!/usr/bin/env bash
# Atualiza Championship Points no Lakebed (PokéData → POST /api/cp/import).
#
# Uso:
#   ./scripts/sync-cp
#   ./scripts/sync-cp --division seniors
#   ./scripts/sync-cp --event-id=0000190
#   npm run sync-cp -- --event-id=0000190
#
# Requer CP_IMPORT_SECRET em .env.lakebed.server (copie de .env.lakebed.server.example).

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

ENV_FILE="$ROOT/.env.lakebed.server"
if [[ -f "$ENV_FILE" ]]; then
  set -a
  while IFS= read -r line || [[ -n "$line" ]]; do
    line="${line%%#*}"
    line="$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    [[ -z "$line" ]] && continue
    export "$line"
  done < "$ENV_FILE"
  set +a
fi

export APP_URL="${APP_URL:-https://vgc-featured-match-finder.lakebed.app}"

exec npx tsx "$ROOT/scripts/sync-cp-to-lakebed.mjs" "$@"
